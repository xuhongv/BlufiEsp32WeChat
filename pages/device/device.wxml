<view class="container">
    <view class="content-scroll">
        <!-- 顶部状态栏 -->
        <view class="status-card">
            <view class="device-name">{{name}}</view>
            <view class="connection-status {{connected ? 'connected' : 'disconnected'}}">
                {{connected ? '已连接' : '已断开'}}
            </view>
        </view>

        <!-- 状态提示 -->
        <view class="status-tips">
            <view>服务状态: {{serviceFound ? '已发现' : '搜索中...'}}</view>
            <view>读通道 (Notify): {{notifyReady ? '就绪' : '未就绪'}}</view>
            <view>写通道 (Write): {{writeReady ? '就绪' : '未就绪'}}</view>
        </view>

        <!-- 日志区域 -->
        <view class="log-area">
            <view class="log-header">
                <text>接收日志</text>
                <text class="clear-log" bindtap="clearLog">清空</text>
            </view>
            <scroll-view scroll-y class="log-scroll" scroll-top="{{scrollTop}}">
                <block wx:for="{{logs}}" wx:key="index">
                    <view class="log-item {{item.type}}">
                        <text class="log-time">[{{item.time}}]</text>
                        <text class="log-content">{{item.content}}</text>
                    </view>
                </block>
                <view wx:if="{{logs.length === 0}}" class="empty-log">暂无日志</view>
            </scroll-view>
        </view>
    </view>

    <!-- 底部快捷指令区域 (固定) -->
    <view class="footer-commands">
        <view class="command-grid">
            <view class="cmd-row">
                <button disabled="{{connected}}" type="primary" class="cmd-btn" bindtap="connectBlueTooth">连接</button>
                <button disabled="{{!connected}}"  class="cmd-btn-warn" bindtap="closeBLEConnection">断开</button>
                <button disabled="{{!connected}}" type="primary" class="cmd-btn" bindtap="startEncrypt">加密</button>
                <button disabled="{{!connected}}" type="primary" class="cmd-btn" bindtap="sendCommandGetVersion">版本</button>
            </view>
            <view class="cmd-row">
                <button disabled="{{!connected}}" type="primary" class="cmd-btn" bindtap="sendCommandNetConfig">配网</button>
                <button disabled="{{!connected}}" type="primary" class="cmd-btn" bindtap="sendCommandGetStatus">状态</button>
                <button disabled="{{!connected}}" type="primary" class="cmd-btn" bindtap="sendCommandScanWiFiList">扫描</button>
                <button disabled="{{!connected}}" type="primary" class="cmd-btn" bindtap="sendCommandCustomData">自定义</button>
            </view>
        </view>
    </view>

    <!-- 配网弹窗 -->
    <view class="modal" wx:if="{{showNetConfigModal}}">
        <view class="modal-content">
            <view class="modal-title">Wi-Fi配网</view>

            <!-- SSID Picker -->
            <view class="ssid-container">
                <picker disabled="{{wifiList.length == 0}}"  class="ssid-picker" bindchange="onWifiPickerChange" value="{{selectedWifiIndex}}" range="{{wifiList}}" range-key="ssidRssi">
                    <view class="picker-display">
                        {{wifiList[selectedWifiIndex].ssidRssi || '请点击右侧刷新获取WiFi列表'}}
                    </view>
                </picker>
                <view class="refresh-btn" bindtap="onRefreshWifiList">🔄</view>
            </view>

            <!-- Password Input -->
            <view class="password-container">
                <input class="modal-input password-input" cursor-spacing="140" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" password="{{!passwordVisible}}" />
                <view class="refresh-btn" bindtap="togglePasswordVisibility">{{passwordVisible ? '👁️' : '🙈'}}</view>
            </view>

            <view class="modal-buttons">
                <button class="modal-btn cancel" bindtap="onCancelNetConfig">取消</button>
                <button class="modal-btn confirm" bindtap="onConfirmNetConfig">确定</button>
            </view>
        </view>
    </view>
</view>